    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@types/cors": "^2.8.19",
    "@types/nodemailer": "^7.0.11",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
