    "db:generate": "npx drizzle-kit generate --config=src/configs/drizzle.config.ts",
    "db:custom": "npx drizzle-kit generate --custom",
    "db:migrate": "npx drizzle-kit migrate --config=src/configs/drizzle.config.ts"
  },
